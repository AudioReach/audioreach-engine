menu "POSAL"

config COMPILE_POSAL
        bool "Compile POSAL source files."
        default n if ARCH_HEXAGON
        default y
        help
           Select y to compile posal source files,
           say n to skip posal source files compilation.

config DLS_DATA_LOGGING
        bool "Enable Data Logging using Data Logging Service (DLS)."
        default y
        help
           Enable Data Logging using Data Logging Service (DLS). DLS service is used on
           platform where DIAG is not supported.

config POSAL_MMAP_NO_MMU
        bool "Identity PA==VA shared memory mapping (no mmap required)"
        default n
        help
           Enable on targets where physical and virtual address spaces are
           identical for shared memory regions. When set, mmap() is skipped
           and the physical address is used directly as the virtual pointer.
           Applicable on targets such as NXP i.MX8 ADSP running Zephyr.

endmenu
